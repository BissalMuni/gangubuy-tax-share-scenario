# Supabase 프로젝트 설정
# https://supabase.com/dashboard → 프로젝트 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 사이트 접근 비밀번호 (로그인 페이지에서 입력)
SITE_PASSWORD=your-site-password

# 관리자 페이지 비밀번호 (/admin 접근 시 요구)
ADMIN_PASSWORD=your-admin-password

# Supabase Service Role Key (GitHub Actions import 전용, 클라이언트에 노출 금지)
# https://supabase.com/dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
